---
const navItems = [
  { href: '/', label: '概览', sub: 'Overview' },
  { href: '/itinerary', label: '行程手册', sub: 'Itinerary' },
  { href: '/destinations', label: '目的地', sub: 'Destinations' },
  { href: '/guide', label: '实用信息', sub: 'Guide' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header
  x-data="{ scrolled: false, mobileOpen: false }"
  @scroll.window="scrolled = window.scrollY > 40"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  :class="scrolled || mobileOpen ? 'bg-ink-deep/95 backdrop-blur-md shadow-lg' : 'bg-transparent'"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div class="flex items-center justify-between h-20">
      <a href="/" class="flex items-center gap-3 group" @click="mobileOpen = false">
        <div class="w-10 h-10 border border-brass/60 flex items-center justify-center rotate-45 group-hover:border-brass transition-colors">
          <span class="-rotate-45 text-brass font-serif text-lg tracking-tight">黑</span>
        </div>
        <div class="leading-tight">
          <div class="text-cream font-serif text-lg tracking-wide">黑蒙吉 · 旅</div>
          <div class="text-brass/80 text-[10px] tracking-[0.3em] uppercase">Heilongjiang Journey</div>
        </div>
      </a>

      <nav class="hidden lg:flex items-center gap-10">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`group relative py-2 transition-colors ${isActive(item.href) ? 'text-brass' : 'text-cream/80 hover:text-cream'}`}
          >
            <span class="block text-sm tracking-wide">{item.label}</span>
            <span class="block text-[9px] tracking-[0.25em] uppercase opacity-60">{item.sub}</span>
            <span
              class={`absolute -bottom-0.5 left-0 h-px bg-brass transition-all duration-300 ${isActive(item.href) ? 'w-full' : 'w-0 group-hover:w-full'}`}
            ></span>
          </a>
        ))}
      </nav>

      <button
        @click="mobileOpen = !mobileOpen"
        class="lg:hidden p-2 text-cream"
        aria-label="切换菜单"
      >
        <svg x-show="!mobileOpen" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="3" y1="7" x2="21" y2="7" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="17" x2="21" y2="17" />
        </svg>
        <svg x-show="mobileOpen" x-cloak width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="18" y1="6" x2="6" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <div
    x-show="mobileOpen"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    class="lg:hidden bg-ink-deep/98 backdrop-blur-md border-t border-brass/20"
  >
    <nav class="px-6 py-4 flex flex-col">
      {navItems.map((item) => (
        <a
          href={item.href}
          @click="mobileOpen = false"
          class={`flex items-center justify-between py-4 border-b border-cream/10 ${isActive(item.href) ? 'text-brass' : 'text-cream'}`}
        >
          <span>
            <span class="block font-serif text-base">{item.label}</span>
            <span class="block text-[10px] tracking-[0.25em] uppercase opacity-50">{item.sub}</span>
          </span>
          <span class="text-brass/60">→</span>
        </a>
      ))}
    </nav>
  </div>
</header>
