---
import BaseLayout from '@layouts/BaseLayout.astro';
import { travelTips, dishes, packageInfo } from '@data/itinerary';

const navItems = [
  { id: 'transport', label: '包车出行', en: 'Transportation' },
  { id: 'packing', label: '行李准备', en: 'Packing' },
  { id: 'safety', label: '安全提示', en: 'Safety' },
  { id: 'etiquette', label: '生态礼仪', en: 'Etiquette' },
  { id: 'hours', label: '开放时间', en: 'Hours' },
  { id: 'emergency', label: '联络应急', en: 'Emergency' },
  { id: 'food', label: '美食地图', en: 'Cuisine' },
  { id: 'package', label: '行程要素', en: 'Package' },
];

// 包车 9 大优势
const carAdvantages = [
  { title: '个性化行程', desc: '按兴趣、节奏、年龄结构自由定制路线，告别千篇一律的跟团节奏。' },
  { title: '舒适便利', desc: '专车全程跟随，告别换乘与搬运行李的疲惫，老人小孩都能轻松出行。' },
  { title: '节省时间', desc: '司机熟悉路况与小众路线，避开拥堵与排队，把更多时间留给风景。' },
  { title: '灵活自由', desc: '随时停车拍照、临时调整景点，遇到心动的小镇不必忍痛错过。' },
  { title: '直达景点', desc: '从酒店到景区门口一站式直达，免去公共交通的转车与步行成本。' },
  { title: '私人空间', desc: '同团皆熟人，行程中的对话、休憩、私密性远超拼车与跟团。' },
  { title: '专业司机', desc: '当地资深司机兼导游，沿途讲解历史风物，是行走的"地方百科"。' },
  { title: '安全有保障', desc: '正规车队、保险齐全、夜间不疲劳驾驶，全程轨迹可追溯。' },
  { title: '行李安置', desc: '18 座中巴空间充足，10 人 8 件行李轻松容纳，购物战利品也不愁。' },
];

// 行李分类（基于 travelTips[1].points 展开）
const packingCategories = [
  {
    name: '衣物',
    en: 'Apparel',
    items: ['薄外套（早晚 15-20℃）', '长袖冲锋衣（伊春林区低 5-8℃）', '速干衣裤', '换洗衣物', '舒适徒步鞋'],
  },
  {
    name: '防护',
    en: 'Protection',
    items: ['防晒霜（边境紫外线强）', '墨镜', '宽沿帽子', '驱蚊液（湿地森林必备）', '口罩'],
  },
  {
    name: '装备',
    en: 'Gear',
    items: ['相机与备用电池', '充电宝（景区续航）', '雨具（折叠伞或雨衣）', '保温水壶', '小背包'],
  },
  {
    name: '证件',
    en: 'Documents',
    items: ['身份证（边境检查）', '护照（如计划赴俄）', '边境通行相关材料', '电子行程单备份', '紧急联系人卡'],
  },
];

// 安全要点（基于 travelTips[2].points）
const safetyPoints = [
  {
    title: '边境禁越',
    detail: '黑河、嘉荫为中俄边境，223 界碑、黑龙江主航道中心线区域严禁跨越国境线，违者将依法处理。',
  },
  {
    title: '水上项目服从指挥',
    detail: '游船、漂流、湿地栈道活动时全程听从工作人员指挥，注意脚下湿滑，儿童须有成人陪护。',
  },
  {
    title: '熔岩台地勿离栈道',
    detail: '火山熔岩台地、龙门石寨区域岩石锋利易伤，禁止偏离木栈道攀爬，避免滑倒与切割伤。',
  },
  {
    title: '野生动物保持距离',
    detail: '金山鹿苑、五营松鼠乐园互动时勿强行抚摸或投喂人工食物，尊重动物习性与安全距离。',
  },
  {
    title: '证件妥善保管',
    detail: '身份证、护照随身保管并做电子备份；边境检查站配合查验，提前备好证件避免延误。',
  },
];

// 生态礼仪（基于 travelTips[3].points）
const etiquettePoints = [
  '五大连池矿泉为稀缺资源，自备瓶接水饮用，不浪费、不污染水源。',
  '红松林、湿地、火山遗址严禁烟火、采摘花果、刻字留念，做静默的过客。',
  '与白头鹤、松鼠等野生动物保持距离，不打扰，不投喂人工食物。',
  '嘉荫恐龙化石区、瑷珲博物馆内禁止使用闪光灯，保护文物与化石。',
  '自驾/包车不乱扔垃圾，所有垃圾带离景区，将整洁还给山林。',
];

// 开放时间表
const hoursTable = [
  { venue: '瑷珲历史陈列馆', hours: '09:00 — 15:30', closed: '周一', note: '4 月 21 日 — 12 月 31 日开放' },
  { venue: '知青博物馆', hours: '09:00 — 16:00', closed: '周一', note: '5 月 1 日 — 9 月 30 日 夏令时段' },
  { venue: '知青博物馆（冬令）', hours: '09:00 — 15:30', closed: '周一', note: '10 月 — 次年 4 月 冬令时段' },
  { venue: '金山屯竹筏漂流', hours: '08:00 — 17:00', closed: '极端天气', note: '约 40 分钟 / 次，团队需 2 筏' },
  { venue: '黑龙江游船', hours: '日间开放', closed: '恶劣天气', note: '建议日落前 1 小时登船' },
  { venue: '汤旺河林海奇石', hours: '08:00 — 17:00', closed: '全年开放', note: '木栈道全程，建议 3-5 小时' },
  { venue: '五营红松林海', hours: '08:00 — 16:30', closed: '全年开放', note: '松鼠乐园上午活跃' },
  { venue: '金山鹿苑', hours: '08:30 — 17:00', closed: '全年开放', note: '上午鹿群活跃，互动体验佳' },
  { venue: '嘉荫恐龙国家地质公园', hours: '08:00 — 17:00', closed: '全年开放', note: '建议 2-3 小时含博物馆' },
];

// 应急联络（基于 travelTips[5].points）
const emergencyContacts = [
  {
    title: '包车司机与导游',
    badge: 'FIRST CONTACT',
    desc: '全程第一联系人，行程调整、突发情况、紧急救援优先联系。',
    accent: 'bg-brass text-ink-deep',
  },
  {
    title: '12301 全国旅游服务热线',
    badge: 'TOURISM HOTLINE',
    desc: '景区救援、旅游投诉、服务质量问题统一受理入口。',
    accent: 'bg-navy text-cream',
  },
  {
    title: '120 / 110',
    badge: 'MEDICAL & POLICE',
    desc: '医疗急救 120、报警 110。边境地区响应迅速，保持通话畅通。',
    accent: 'bg-[#8b2c2c] text-cream',
  },
  {
    title: '黑河边境事务',
    badge: 'BORDER ASSIST',
    desc: '边境相关问题可咨询酒店前台或当地派出所，配合边防检查。',
    accent: 'bg-ink text-cream',
  },
  {
    title: '旅行意外险建议',
    badge: 'INSURANCE',
    desc: '建议购买包含边境游、户外活动、医疗救援的综合旅行意外险。',
    accent: 'bg-navy-deep text-cream',
  },
];
---

<BaseLayout
  title="实用信息中心 | 黑蒙吉 · 旅"
  description="包车说明、行李准备、安全提示、生态礼仪、开放时间、应急联络——黑蒙吉旅 13 天深度行程的实用信息手册。"
  ogImage="/images/hero/hero-yichun-forest.jpg"
>
  <!-- ============ Banner ============ -->
  <section class="relative w-full h-[400px] lg:h-[420px] overflow-hidden">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url('/images/hero/hero-yichun-forest.jpg');"
    ></div>
    <div class="absolute inset-0" style="background: rgba(15, 41, 41, 0.7);"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-ink-deep/60 via-transparent to-transparent"></div>

    <div class="relative h-full max-w-7xl mx-auto px-6 lg:px-10 flex flex-col justify-center">
      <div class="max-w-3xl">
        <span class="inline-block text-brass text-xs tracking-[0.35em] uppercase font-semibold mb-5">
          Practical Guide · 实用信息
        </span>
        <h1 class="text-cream font-serif text-4xl md:text-5xl lg:text-6xl leading-tight tracking-wide">
          让每一次出发<br />都从容不迫
        </h1>
        <div class="w-16 h-px bg-brass/60 my-7"></div>
        <p class="text-cream/80 text-base lg:text-lg leading-relaxed max-w-2xl">
          包车说明、行李准备、安全提示、生态礼仪、开放时间、应急联络——一册在手，行程无忧。
        </p>
      </div>
    </div>
  </section>

  <!-- Shared Alpine context for mobile sticky nav + desktop sidebar + scroll spy -->
  <div x-data="guideSpy()" x-init="init()">
    <!-- ============ Mobile Sticky Nav ============ -->
    <div
      class="lg:hidden sticky top-20 z-30 bg-cream/95 backdrop-blur-md border-b border-brass/20 shadow-sm"
    >
      <div class="overflow-x-auto scrollbar-hide -mx-1 px-1">
        <div class="flex gap-1 px-4 py-3 whitespace-nowrap">
          <template x-for="item in navItems" :key="item.id">
            <a
              :href="'#' + item.id"
              class="px-4 py-2 text-xs tracking-wider rounded-full border transition-colors"
              :class="active === item.id ? 'bg-ink text-cream border-ink' : 'text-ink/70 border-brass/30 hover:border-brass'"
              x-text="item.label"
            ></a>
          </template>
        </div>
      </div>
    </div>

    <!-- ============ Main Layout ============ -->
    <div class="max-w-7xl mx-auto px-6 lg:px-10 pt-14 lg:pt-20 pb-20">
    <div class="lg:grid lg:grid-cols-12 lg:gap-12">

      <!-- Desktop Sticky Sidebar -->
      <aside class="hidden lg:block lg:col-span-3">
        <div class="sticky top-28">
          <div class="label-eyebrow !mb-5">On This Page</div>
          <nav class="space-y-1 border-l border-brass/25">
            {navItems.map((item) => (
              <a
                href={`#${item.id}`}
                class="group block pl-5 py-2.5 border-l-2 -ml-px transition-all"
                :class={`active === '${item.id}' ? 'border-brass bg-brass/5' : 'border-transparent hover:border-brass/40'`}
                :data-target={item.id}
              >
                <div
                  class="text-sm font-medium transition-colors"
                  :class={`active === '${item.id}' ? 'text-ink' : 'text-ink/55 group-hover:text-ink'`}
                >
                  {item.label}
                </div>
                <div class="text-[10px] tracking-[0.2em] uppercase opacity-50 mt-0.5">
                  {item.en}
                </div>
              </a>
            ))}
          </nav>

          <div class="mt-10 p-5 bg-ink/5 border border-brass/20">
            <div class="text-[10px] tracking-[0.3em] uppercase text-brass-dark font-semibold mb-2">
              Quick Reference
            </div>
            <div class="text-xs text-ink/70 leading-relaxed">
              全程 13 天 · 18 座中巴包车<br />
              10 人精品小团 · 司导全程跟随<br />
              黑河 · 嘉荫 边境段注意证件
            </div>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <div class="lg:col-span-9 space-y-24">

        <!-- ============ 1. 包车说明 ============ -->
        <section id="transport" class="scroll-mt-28 section-fade">
          <div class="mb-10">
            <span class="label-eyebrow">Transportation · 包车出行</span>
            <h2 class="text-ink font-serif text-3xl lg:text-4xl tracking-wide">
              18 座中巴，全程 10 人 8 件行李
            </h2>
            <div class="brass-rule mt-5"></div>
          </div>

          <!-- 车型信息 -->
          <div class="bg-ink text-cream p-8 lg:p-10 mb-8 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-48 h-48 bg-brass/10 rounded-full -mr-16 -mt-16"></div>
            <div class="relative grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
              <div>
                <div class="text-brass text-[10px] tracking-[0.3em] uppercase mb-2">车型</div>
                <div class="text-2xl font-serif">18 座中巴</div>
              </div>
              <div>
                <div class="text-brass text-[10px] tracking-[0.3em] uppercase mb-2">乘客</div>
                <div class="text-2xl font-serif">10 位</div>
              </div>
              <div>
                <div class="text-brass text-[10px] tracking-[0.3em] uppercase mb-2">行李</div>
                <div class="text-2xl font-serif">8 件</div>
              </div>
              <div>
                <div class="text-brass text-[10px] tracking-[0.3em] uppercase mb-2">用车时长</div>
                <div class="text-2xl font-serif">8 小时/天</div>
              </div>
            </div>
          </div>

          <!-- 服务亮点（5 张小卡） -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-12">
            {travelTips[0].points.map((point, i) => {
              const titles = ['超时计费', '自由定制', '专业讲解', '私密舒适', '直达免换乘'];
              return (
                <div class="bg-white/60 border border-brass/20 p-5 card-shadow card-shadow-hover">
                  <div class="w-10 h-10 bg-brass/15 text-brass-dark flex items-center justify-center mb-4 font-serif text-lg">
                    {String(i + 1).padStart(2, '0')}
                  </div>
                  <div class="text-sm font-serif text-ink font-medium mb-2">{titles[i]}</div>
                  <div class="text-xs text-ink/65 leading-relaxed">{point}</div>
                </div>
              );
            })}
          </div>

          <!-- 9 大优势 -->
          <div>
            <div class="flex items-baseline justify-between mb-6">
              <h3 class="font-serif text-xl text-ink">包车出行的 9 大优势</h3>
              <span class="text-[10px] tracking-[0.3em] uppercase text-brass-dark">Why Charter</span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-brass/20 border border-brass/20">
              {carAdvantages.map((adv, i) => (
                <div class="bg-cream p-6 hover:bg-white transition-colors">
                  <div class="flex items-start gap-4">
                    <div class="text-brass-dark font-serif text-2xl leading-none mt-1">
                      {String(i + 1).padStart(2, '0')}
                    </div>
                    <div class="flex-1">
                      <div class="font-serif text-ink text-base mb-2">{adv.title}</div>
                      <div class="text-xs text-ink/65 leading-relaxed">{adv.desc}</div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        <!-- ============ 2. 行李准备 ============ -->
        <section id="packing" class="scroll-mt-28 section-fade">
          <div class="mb-10">
            <span class="label-eyebrow">Packing · 行李准备</span>
            <h2 class="text-ink font-serif text-3xl lg:text-4xl tracking-wide">
              7 月东北 · 早晚温差的打包指南
            </h2>
            <div class="brass-rule mt-5"></div>
            <p class="mt-5 text-sm text-ink/65 leading-relaxed max-w-2xl">
              夏季黑龙江白天 25-30℃，林区温度比城市低 5-8℃，边境紫外线强。建议按以下 4 类准备，可点击勾选已备物品。
            </p>
          </div>

          <div
            class="grid grid-cols-1 md:grid-cols-2 gap-6"
            x-data="{ checked: {} }"
          >
            {packingCategories.map((cat, ci) => (
              <div class="bg-white/60 border border-brass/20 p-6 lg:p-7 card-shadow">
                <div class="flex items-baseline justify-between border-b border-brass/15 pb-4 mb-5">
                  <div>
                    <div class="font-serif text-lg text-ink">{cat.name}</div>
                    <div class="text-[10px] tracking-[0.3em] uppercase text-brass-dark mt-1">{cat.en}</div>
                  </div>
                  <div class="text-xs text-ink/40 font-serif">{cat.items.length} 项</div>
                </div>
                <ul class="space-y-2.5">
                  {cat.items.map((item, ii) => {
                    const key = `c${ci}-i${ii}`;
                    return (
                      <li
                        class="flex items-center gap-3 cursor-pointer select-none group"
                        @click={`checked['${key}'] = !checked['${key}']`}
                      >
                        <span
                          class="flex-shrink-0 w-5 h-5 border border-ink/40 flex items-center justify-center transition-all group-hover:border-brass"
                          :class={`checked['${key}'] ? 'bg-brass border-brass' : 'bg-transparent'`}
                        >
                          <svg
                            x-show={`checked['${key}']`}
                            width="12" height="12" viewBox="0 0 24 24" fill="none"
                            stroke="#1a3a3a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"
                          >
                            <polyline points="20 6 9 17 4 12" />
                          </svg>
                        </span>
                        <span
                          class="text-sm text-ink/80 transition-all group-hover:text-ink"
                          :class={`checked['${key}'] ? 'line-through opacity-50' : ''`}
                        >
                          {item}
                        </span>
                      </li>
                    );
                  })}
                </ul>
              </div>
            ))}
          </div>
        </section>

        <!-- ============ 3. 安全提示 ============ -->
        <section id="safety" class="scroll-mt-28 section-fade">
          <div class="mb-10">
            <span class="label-eyebrow">Safety · 安全提示</span>
            <h2 class="text-ink font-serif text-3xl lg:text-4xl tracking-wide">
              边境与户外 · 五条必读守则
            </h2>
            <div class="brass-rule mt-5"></div>
          </div>

          <div class="space-y-4">
            {safetyPoints.map((p, i) => (
              <div class="bg-white/60 border-l-4 border-l-[#8b2c2c] border-y border-r border-brass/20 p-6 lg:p-7 card-shadow card-shadow-hover">
                <div class="flex items-start gap-5 lg:gap-7">
                  <div class="flex-shrink-0 font-serif text-4xl lg:text-5xl text-brass-dark leading-none">
                    {String(i + 1).padStart(2, '0')}
                  </div>
                  <div class="flex-1 pt-1">
                    <div class="flex items-center gap-3 mb-2">
                      <h3 class="font-serif text-lg lg:text-xl text-ink">{p.title}</h3>
                      <span class="text-[10px] tracking-[0.25em] uppercase text-[#8b2c2c] font-semibold border border-[#8b2c2c]/40 px-2 py-0.5">
                        CAUTION
                      </span>
                    </div>
                    <p class="text-sm text-ink/70 leading-relaxed">{p.detail}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- ============ 4. 生态礼仪 ============ -->
        <section id="etiquette" class="scroll-mt-28 section-fade">
          <div class="mb-10">
            <span class="label-eyebrow">Etiquette · 生态礼仪</span>
            <h2 class="text-ink font-serif text-3xl lg:text-4xl tracking-wide">
              守护火山与森林的静默约定
            </h2>
            <div class="brass-rule mt-5"></div>
          </div>

          <!-- 名言装饰 -->
          <div class="bg-ink/5 border-l-4 border-brass px-7 py-6 mb-8">
            <p class="font-serif italic text-lg lg:text-xl text-ink/85 leading-relaxed">
              "取之自然，还之自然。我们只是这片土地短暂的过客，留下脚印，带走记忆。"
            </p>
            <div class="mt-3 text-[10px] tracking-[0.3em] uppercase text-brass-dark">Leave No Trace</div>
          </div>

          <div class="space-y-4">
            {etiquettePoints.map((point, i) => (
              <div class="border-l-4 border-brass pl-6 py-3 bg-white/40">
                <div class="flex items-start gap-4">
                  <span class="font-serif text-brass-dark text-xl leading-none mt-1">"{i + 1}"</span>
                  <p class="font-serif italic text-base lg:text-lg text-ink/85 leading-relaxed flex-1">
                    {point}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- ============ 5. 开放时间表 ============ -->
        <section id="hours" class="scroll-mt-28 section-fade">
          <div class="mb-10">
            <span class="label-eyebrow">Hours · 开放时间</span>
            <h2 class="text-ink font-serif text-3xl lg:text-4xl tracking-wide">
              重要场馆与项目时刻一览
            </h2>
            <div class="brass-rule mt-5"></div>
            <p class="mt-5 text-sm text-ink/65 leading-relaxed">
